    <section class="cta-block content-block">
        <div class="full-bck" style="background-image: url('/assets/img/cta.webp')"></div>
        <div class="container">
            <div class="row">
                <div class="col-12 col-lg-8 offset-lg-2">
                    <h2 class="title">Need help choosing?</h2>
                    <div class="text">
                        Not sure which car is right for you? Contact us and we’ll be happy to help you choose. Together, we’ll find a car that fits both your needs and your budget.
                    </div>
                    <div class="btn-wrap">
