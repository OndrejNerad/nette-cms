#!/usr/bin/env php
<?php declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

$bootstrap = new App\Bootstrap;
$container = $bootstrap->bootCliApplication();

$app = new Symfony\Component\Console\Application('CMS', '1.0');
$app->add($container->getByType(App\Command\ImportCarsCommand::class));
$app->add($container->getByType(App\Command\ReprocessCarImagesCommand::class));
//$app->add($container->getByType(App\Command\ImportSocialItemsCommand::class));
//$app->add($container->getByType(App\Command\ImportGoogleReviewsCommand::class));
$app->run();