services:
    mail.mailer:
        class: Nette\Mail\SmtpMailer
        arguments:
            host: mailhog
            port: 1025
            username: ''
            password: ''
            encryption: null

    - App\Core\RouterFactory::createRouter
    - App\Components\Forms\ContactFormFactory(@mail.mailer, %adminEmail%)
    - implement: App\Components\Forms\ContactFormControlFactory

search:
    - in: %appDir%
      classes:
        - *Facade
        - *Factory
        - *Repository
        - *Service